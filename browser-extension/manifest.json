{
  "manifest_version": 3,
  "name": "OmniFlow AI",
  "version": "1.0.0",
  "description": "AI-powered browser assistant",

  "action": {
    "default_popup": "popup/popup.html"
  },

  "background": {
    "service_worker": "background/background.js"
  },

  "permissions": [
    "storage",
    "activeTab"
  ]
}
